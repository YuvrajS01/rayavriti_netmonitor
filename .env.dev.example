# ─── Server ───────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── Security ─────────────────────────────────────────────────
JWT_SECRET=dev-only-change-me-at-least-32-characters
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# ─── API Keys ─────────────────────────────────────────────────
DEFAULT_API_KEY=

# ─── Database (PostgreSQL + TimescaleDB) ──────────────────────
DATABASE_URL=postgres://netmonitor:netmonitor@localhost:5432/netmonitor?sslmode=disable
POSTGRES_DB=netmonitor
POSTGRES_USER=netmonitor
POSTGRES_PASSWORD=netmonitor
DB_MAX_CONNS=20
DB_MIN_CONNS=2
DB_MAX_CONN_LIFETIME=1h
DB_HEALTH_CHECK_PERIOD=30s

# ─── Data Retention ───────────────────────────────────────────
METRICS_RETENTION_DAYS=7
FLOWS_RETENTION_DAYS=2
ALERTS_RETENTION_DAYS=14

# ─── Monitoring Tables Retention ──────────────────────────────
MON_HTTP_RETENTION_DAYS=7
MON_DB_RETENTION_DAYS=3
MON_COLLECTOR_RETENTION_DAYS=14
MON_AUDIT_RETENTION_DAYS=365
MON_HEALTH_RETENTION_DAYS=30
MON_ALERT_RETENTION_DAYS=30

# ─── Network Collectors ──────────────────────────────────────
NETFLOW_PORT=2055
PORT_DISCOVERY_ENABLED=true
PORT_DISCOVERY_INTERVAL_MINUTES=60
PORT_SCAN_TIMEOUT_MS=900
PORT_SCAN_CONCURRENCY=16
CAPTURE_ENABLED=false

# ─── Logging ──────────────────────────────────────────────────
LOG_LEVEL=debug
LOG_FORMAT=pretty
LOG_FILE_ENABLED=false
LOG_FILE_PATH=./data/logs/netmonitor.log
LOG_FILE_MAX_SIZE_MB=100
LOG_FILE_MAX_BACKUPS=10
LOG_FILE_MAX_AGE_DAYS=30
LOG_FILE_COMPRESS=true
LOG_DB_ENABLED=true
LOG_DB_SAMPLE_RATE=1.0
LOG_DB_QUEUE_SIZE=10000
LOG_DB_DROP_POLICY=drop_debug
LOG_MODULE_LEVELS=
LOG_SLOW_QUERY_MS=100
LOG_SLOW_REQUEST_MS=1000

# ─── Phase 2: Notification Channels ───────────────────────────
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_FROM=
STATUS_PAGE_ENABLED=false