# ─── Server ───────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── Security ─────────────────────────────────────────────────
JWT_SECRET=dev-only-change-me-at-least-32-characters
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# ─── API Keys ─────────────────────────────────────────────────
DEFAULT_API_KEY=

# ─── Database ─────────────────────────────────────────────────
DB_PATH=/app/data/netmonitor-dev.db

# ─── Data Retention ───────────────────────────────────────────
METRICS_RETENTION_DAYS=7
FLOW_RETENTION_DAYS=2
ALERTS_RETENTION_DAYS=14

# ─── Network Collectors ──────────────────────────────────────
NETFLOW_PORT=2055
PORT_DISCOVERY_ENABLED=true
PORT_DISCOVERY_INTERVAL_MINUTES=60
PORT_SCAN_TIMEOUT_MS=900
PORT_SCAN_CONCURRENCY=16
CAPTURE_ENABLED=false
