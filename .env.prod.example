# ─── Server ───────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ─── Security ─────────────────────────────────────────────────
# REQUIRED: generate with `openssl rand -base64 32`
JWT_SECRET=
ADMIN_USERNAME=admin
# REQUIRED: set to the production admin password before first boot
ADMIN_PASSWORD=

# ─── API Keys ─────────────────────────────────────────────────
DEFAULT_API_KEY=

# ─── Database ─────────────────────────────────────────────────
DB_PATH=/app/data/netmonitor.db

# ─── Data Retention ───────────────────────────────────────────
METRICS_RETENTION_DAYS=30
FLOW_RETENTION_DAYS=7
ALERTS_RETENTION_DAYS=90

# ─── Network Collectors ──────────────────────────────────────
NETFLOW_PORT=2055
PORT_DISCOVERY_ENABLED=true
PORT_DISCOVERY_INTERVAL_MINUTES=60
PORT_SCAN_TIMEOUT_MS=900
PORT_SCAN_CONCURRENCY=16
CAPTURE_ENABLED=true
