{
  "name": "rayavriti-netmonitor",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": "20.x || 22.x || 26.x"
  },
  "description": "Rayavriti NetMonitor — production-grade network monitoring platform",
  "workspaces": [
    "client"
  ],
  "scripts": {
    "dev": "cd backend && make run",
    "dev:server": "cd backend && make run",
    "dev:client": "npm run dev -w client",
    "build": "cd backend && make build && npm run build -w client",
    "build:server": "cd backend && make build",
    "build:client": "npm run build -w client",
    "start": "./backend/bin/netmonitor",
    "start:prod": "NODE_ENV=production ./backend/bin/netmonitor",
    "simulate": "npx ts-node simulator/run.ts"
  }
}
